SELECT * FROM eleitor;

SELECT nome_completo FROM eleitor WHERE status_voto = 'JA_VOTOU';

SELECT c.nome, COUNT(v.id) AS total_votos
FROM candidato c
LEFT JOIN voto v ON c.id = v.id_candidato
GROUP BY c.nome;

SELECT c.nome, COUNT(v.id) AS votos
FROM candidato c
JOIN voto v ON c.id = v.id_candidato
GROUP BY c.nome
ORDER BY votos DESC
LIMIT 1;