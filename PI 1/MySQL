CREATE DATABASE sistema_votacao;
USE sistema_votacao;

CREATE TABLE eleitor (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome_completo VARCHAR(150) NOT NULL,
    cpf VARCHAR(50) NOT NULL UNIQUE, -- armazenado criptografado
    titulo_eleitor VARCHAR(20) NOT NULL UNIQUE,
    mesario BOOLEAN NOT NULL,
    chave_acesso VARCHAR(50) NOT NULL, -- criptografada
    status_voto ENUM('NAO_VOTOU', 'JA_VOTOU') DEFAULT 'NAO_VOTOU'
);

CREATE TABLE candidato (
    id INT AUTO_INCREMENT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    numero INT NOT NULL UNIQUE,
    partido VARCHAR(50) NOT NULL
);

CREATE TABLE voto (
    id INT AUTO_INCREMENT PRIMARY KEY,
    id_candidato INT,
    data_hora DATETIME NOT NULL,
    protocolo VARCHAR(50) NOT NULL, -- criptografado
    FOREIGN KEY (id_candidato) REFERENCES candidato(id)
);

CREATE TABLE log_ocorrencias (
    id INT AUTO_INCREMENT PRIMARY KEY,
    data_hora DATETIME NOT NULL,
    descricao TEXT NOT NULL
);

